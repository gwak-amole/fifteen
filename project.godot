; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="fifteen"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

DialogueManager="*uid://c3rodes2l3gxb"
DialogueHandler="*uid://0k11lidks7gk"

[dialogue_manager]

runtime/balloon_path="uid://bwrhs3qwe7q6q"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/godot_super-wakatime/plugin.cfg")

[internationalization]

locale/translations_pot_files=PackedStringArray("res://dialogues/lamp_interaction.dialogue", "res://dialogues/computer_interaction.dialogue")

[physics]

3d/physics_engine="Jolt Physics"
2d/default_gravity=0.0
2d/default_gravity_vector=Vector2(0, 0)

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
